<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.fixit">

    <application
    android:allowBackup="true"
    android:icon="@mipmap/ic_launcher"
    android:label="@string/app_name"
    android:roundIcon="@mipmap/ic_launcher_round"
    android:supportsRtl="true"
    android:theme="@style/Theme.FixIt">

    <!-- Launcher -->
    <activity android:name=".MainActivity" android:exported="true">
        <intent-filter>
            <action android:name="android.intent.action.MAIN"/>
            <category android:name="android.intent.category.LAUNCHER"/>
        </intent-filter>
    </activity>

    <!-- Onboarding Screens -->
    <activity android:name=".OnboardingActivity" android:exported="true"/>
    <activity android:name=".OnboardingActivity2" android:exported="true"/>
    <activity android:name=".OnboardingActivity3" android:exported="true"/>

    <!-- Welcome Screen -->
    <activity android:name=".WelcomeActivity" android:exported="true"/>

    <!-- Login and Signup Screens -->
    <activity android:name=".LoginActivity" android:exported="true"/>
    <activity android:name=".SignupActivity" android:exported="true"/>

    <!-- Home Screen -->
    <activity android:name=".HomeActivity" android:exported="true"/>

    <!-- Tips Screen -->
    <activity android:name=".TipsActivity" android:exported="true"/>

    <!-- Booking Screen -->
    <activity android:name=".BookinggActivity" android:exported="true" />

    <!-- Booking Screen -->
    <activity android:name=".ProfileActivity" android:exported="true"/>

    <!-- Detail Screen1 -->
    <activity android:name=".DetailScreen1Activity" android:exported="true"/>

    <!-- Detail Screen2 -->
    <activity android:name=".DetailScreen2Activity" android:exported="true"/>



</application>

</manifest>



